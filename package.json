{
  "name": "axios-eventsource-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r build",
    "tsc": "tsgo -b",
    "dev": "pnpm --parallel --filter axios-eventsource --filter example-express-server --filter example-fastify-server --filter example-website dev",
    "test": "vitest run",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "make-release": "node scripts/make-release.mjs packages/axios-eventsource"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20251229.1",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.17.0"
}
