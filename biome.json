{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "files": {
    "includes": [
      "packages/*/src/**/*",
      "examples/*/src/**/*",
      "**/package.json",
      "**/vite*.config.ts",
      "!**/routeTree.gen.ts"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
